# Database Connection
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/foodflow_erp?schema=public"

# Environment
NODE_ENV=development
PORT=4000

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRATION=7d

# GraphQL
GRAPHQL_PLAYGROUND=true
GRAPHQL_DEBUG=true

# WhatsApp Business API
WHATSAPP_BUSINESS_PHONE_ID=your_phone_id
WHATSAPP_BUSINESS_ACCESS_TOKEN=your_access_token
WHATSAPP_BUSINESS_API_URL=https://graph.instagram.com/v18.0

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# GraphQL Rate Limiting
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_SEC=60
ENABLE_SENSITIVE_MUTATION_RATE_LIMIT=false
SENSITIVE_RATE_LIMIT_MAX=30
SENSITIVE_RATE_LIMIT_WINDOW_SEC=60
SENSITIVE_MUTATIONS=createOrder,updateOrderStatus,deleteOrder,createProduct,updateProduct,deleteProduct

# File Upload (AWS S3 or similar)
AWS_S3_BUCKET=your_bucket_name
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Email Service (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=noreply@foodflow.com

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_IN_TESTS=false
