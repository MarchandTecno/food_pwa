# ==============================
# FoodFlow Backend - Production
# ==============================

# Runtime
NODE_ENV=production
PORT=4000

# Database (required)
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>?schema=public

# JWT (required)
JWT_SECRET=<set-a-strong-random-secret-min-32-chars>
JWT_EXPIRATION=15m

# CORS (required in production)
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com

# GraphQL / Apollo
GRAPHQL_PLAYGROUND=false
GRAPHQL_DEBUG=false

# Rate limiting
# Auth mutations (login/register)
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_SEC=60

# Optional: sensitive mutations
ENABLE_SENSITIVE_MUTATION_RATE_LIMIT=true
SENSITIVE_RATE_LIMIT_MAX=30
SENSITIVE_RATE_LIMIT_WINDOW_SEC=60
SENSITIVE_MUTATIONS=createOrder,updateOrderStatus,deleteOrder,createProduct,updateProduct,deleteProduct

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
